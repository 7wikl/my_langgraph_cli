# LLM Configuration
LLM_MODEL_NAME=gpt-4
LLM_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_api_key_here

# PostgreSQL Database for LangGraph Checkpointer
POSTGRES_DATABASE_URI=postgresql://username:password@localhost:5432/financial_agent

# LangFuse Configuration (for logging and tracing)
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_BASE_URL=http://localhost:3000

# Environment
PYTHON_ENV=development

# Redis Configuration (optional, for caching)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# AI SQL API (StockSelect)
AI_SQL_URL=http://192.168.1.239:81/zmcp/stockselect

# Execute SQL API
EXECUTE_SQL_URL=http://localhost:8080/api/execute-sql
ASSET_CONTROL_KEY=your_asset_control_key_here
